# ========================================
# SQL报表查询系统 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ========================================

# 数据库连接配置
DB_URL=jdbc:oracle:thin:@your-server:1521:orcl
DB_USERNAME=your_username
DB_PASSWORD=your_password

# 管理员账号配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_password_at_least_8_chars

# 应用目录配置
APP_LOG_DIR=./logs
APP_DATA_DIR=./data
APP_SCRIPTS_DIR=./scripts
